# ─────────────────────────────────────────────────────────────
# SMTP Validator API — environment variables
# Copy this file to `.env` and adjust values for your machine.
#   PowerShell:  Copy-Item .env.example .env
#   bash:        cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Runtime mode: development | production | test
NODE_ENV=development

# HTTP port the API listens on. Swagger is served at http://localhost:PORT/docs
PORT=3000

# PostgreSQL connection string used by Prisma.
# Matches the credentials in docker-compose.yml.
# NOTE: if host port 5432 is already taken on your machine, publish the
# container on a free port (e.g. 55433:5432 via a docker-compose.override.yml)
# and change the port below to match.
DATABASE_URL=postgresql://smtp_validator:smtp_validator@localhost:5432/smtp_validator_db

# Static API key required by the /api/validate/* endpoints (header: x-api-key).
# Use a strong, random value in production.
API_KEY=development-key

# Per-query DNS lookup timeout in milliseconds. On timeout/error the API
# returns status "unknown" instead of failing the request.
DNS_TIMEOUT_MS=5000

# ─────────────────────────────────────────────────────────────
# SMTP Probe Configuration
# ─────────────────────────────────────────────────────────────
SMTP_VALIDATION_ENABLED=false
SMTP_CONNECT_TIMEOUT_MS=8000
SMTP_READ_TIMEOUT_MS=8000
SMTP_EHLO_NAME=mail.validator.example.com
SMTP_MAIL_FROM=probe@validator.example.com
SMTP_STARTTLS_ENABLED=true
SMTP_PIPELINING_ENABLED=false

# Queue & Rate Limiting (Concurrency & Cooldown)
SMTP_GLOBAL_CONCURRENCY=10
SMTP_DOMAIN_CONCURRENCY=1
SMTP_PROVIDER_CONCURRENCY_DEFAULT=2
SMTP_PROVIDER_CONCURRENCY_GMAIL=1
SMTP_PROVIDER_CONCURRENCY_OUTLOOK=1
SMTP_PROVIDER_CONCURRENCY_YAHOO=1

# Retry & Cooldown Policies
SMTP_MAX_RETRIES=1
SMTP_RETRY_BACKOFF_MS=30000
SMTP_PROVIDER_COOLDOWN_MS=60000
SMTP_DOMAIN_COOLDOWN_MS=60000

# Catch-All Domain Detection
SMTP_CATCH_ALL_CHECK_ENABLED=false
SMTP_CATCH_ALL_RANDOM_PREFIX=verify
SMTP_CATCH_ALL_TIMEOUT_MS=8000
SMTP_CATCH_ALL_SKIP_PROVIDERS=gmail,outlook,yahoo

# Domain Behavior Cache
DOMAIN_BEHAVIOR_CACHE_ENABLED=true
DOMAIN_BEHAVIOR_CACHE_TTL_MS=86400000
DOMAIN_BEHAVIOR_MIN_SAMPLE_SIZE=3
